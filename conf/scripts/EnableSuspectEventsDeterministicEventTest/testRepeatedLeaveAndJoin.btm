AT ENTRY
IF TRUE
DO
    System.out.println("--> " + Thread.currentThread().getName().substring(Thread.currentThread().getName().lastIndexOf(",") + 1) + " [T5] notifyConnectionClosed(" + $1 + ") node=" + $0.localAddress() + " thread=" + Thread.currentThread().getName())
